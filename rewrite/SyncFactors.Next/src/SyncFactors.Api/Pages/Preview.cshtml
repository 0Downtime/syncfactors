@page
@model SyncFactors.Api.Pages.PreviewModel
@{
    ViewData["Title"] = "Worker Preview";
}

<section class="hero hero-compact">
    <div>
        <p class="eyebrow">Staging Sync</p>
        <h1>Worker Preview</h1>
        <p class="lede">Enter a worker ID to fetch the worker from SuccessFactors, compare it to Active Directory, and inspect the staged operations before a real sync.</p>
    </div>
</section>

<section class="panel">
    <form method="get" class="filters preview-form" data-worker-lookup-form>
        <label class="filter-search">
            <span>Worker Id</span>
            <input type="text" name="workerId" value="@Model.WorkerId" placeholder="1000123" />
        </label>
        <div class="filter-actions">
            <button type="submit" data-worker-lookup-button>
                <span class="button-label">Preview Worker</span>
                <span class="button-spinner" aria-hidden="true"></span>
            </button>
        </div>
    </form>
</section>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <section class="panel">
        <p class="callout danger">@Model.ErrorMessage</p>
    </section>
}

@if (Model.ApplyResult is not null)
{
    <section class="panel">
        <p class="callout @(Model.ApplyResult.Succeeded ? "good" : "danger")">@Model.ApplyResult.Message</p>
        <dl class="kv preview-meta">
            <div><dt>Action</dt><dd>@Model.ApplyResult.Action</dd></div>
            <div><dt>SAM</dt><dd>@Model.ApplyResult.SamAccountName</dd></div>
            <div><dt>Distinguished Name</dt><dd>@(Model.ApplyResult.DistinguishedName ?? "n/a")</dd></div>
            <div><dt>Run</dt><dd>
                @if (!string.IsNullOrWhiteSpace(Model.ApplyResult.RunId))
                {
                    <a asp-page="/Runs/Detail" asp-route-runId="@Model.ApplyResult.RunId">@Model.ApplyResult.RunId</a>
                }
                else
                {
                    <text>n/a</text>
                }
            </dd></div>
        </dl>
    </section>
}

@if (Model.Preview is not null)
{
    var resolvedAttributes = Model.Preview.SourceAttributes
        .Where(attribute => !IsPathLikeAttribute(attribute.Attribute))
        .ToArray();
    var sourcePathAttributes = Model.Preview.SourceAttributes
        .Where(attribute => IsPathLikeAttribute(attribute.Attribute))
        .ToArray();

    <section class="panel-grid preview-summary-grid">
        <article class="panel">
            <h2>Summary</h2>
            <dl class="kv">
                <div><dt>Worker Id</dt><dd><span class="summary-value" title="@Model.Preview.WorkerId" tabindex="0">@Model.Preview.WorkerId</span></dd></div>
                <div><dt>SAM</dt><dd><span class="summary-value" title="@(Model.Preview.SamAccountName ?? "n/a")" tabindex="0">@(Model.Preview.SamAccountName ?? "n/a")</span></dd></div>
                <div><dt>Status</dt><dd><span class="summary-value" title="@(Model.Preview.Status ?? "Unknown")" tabindex="0">@(Model.Preview.Status ?? "Unknown")</span></dd></div>
                <div><dt>Operation</dt><dd><span class="summary-value" title="@(Model.Preview.OperationSummary?.Action ?? "No operation")" tabindex="0">@(Model.Preview.OperationSummary?.Action ?? "No operation")</span></dd></div>
                <div><dt>Matched Existing User</dt><dd><span class="summary-value" title="@DisplayBool(Model.Preview.MatchedExistingUser)" tabindex="0">@DisplayBool(Model.Preview.MatchedExistingUser)</span></dd></div>
                <div><dt>Manager DN</dt><dd><span class="summary-value" title="@(Model.Preview.ManagerDistinguishedName ?? "n/a")" tabindex="0">@(Model.Preview.ManagerDistinguishedName ?? "n/a")</span></dd></div>
                <div><dt>Current DN</dt><dd><span class="summary-value" title="@(Model.Preview.CurrentDistinguishedName ?? "n/a")" tabindex="0">@(Model.Preview.CurrentDistinguishedName ?? "n/a")</span></dd></div>
                <div><dt>Target OU</dt><dd><span class="summary-value" title="@(Model.Preview.TargetOu ?? "n/a")" tabindex="0">@(Model.Preview.TargetOu ?? "n/a")</span></dd></div>
                <div><dt>Preview Log</dt><dd><span class="summary-value" title="@(Model.Preview.ReportPath ?? "n/a")" tabindex="0">@(Model.Preview.ReportPath ?? "n/a")</span></dd></div>
            </dl>
            @if (!string.IsNullOrWhiteSpace(Model.Preview.OperationSummary?.Effect))
            {
                <p class="callout">@Model.Preview.OperationSummary.Effect</p>
            }
            <form method="post" asp-page-handler="Apply" data-worker-apply-form>
                <input type="hidden" asp-for="WorkerId" />
                <div class="filter-actions">
                    <button type="submit" data-worker-apply-button>
                        <span class="button-label">Apply Preview</span>
                        <span class="button-spinner" aria-hidden="true"></span>
                    </button>
                </div>
            </form>
        </article>

        <article class="panel">
            <h2>Classification</h2>
            <div class="bucket-grid">
            @foreach (var bucket in Model.Preview.Buckets)
            {
                <span class="bucket-card">@bucket</span>
            }
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.Preview.Reason) || !string.IsNullOrWhiteSpace(Model.Preview.ReviewCaseType))
            {
                <dl class="kv preview-meta">
                    <div><dt>Reason</dt><dd>@(Model.Preview.Reason ?? "n/a")</dd></div>
                    <div><dt>Review Case</dt><dd>@(Model.Preview.ReviewCaseType ?? "n/a")</dd></div>
                </dl>
            }
        </article>
    </section>

    <section class="panel">
        <h2>Attribute Diff</h2>
        @if (Model.Preview.DiffRows.Count == 0)
        {
            <p class="muted">No synced attributes were recorded for this preview.</p>
        }
        else
        {
            <p class="muted">Showing every synced attribute with the current directory value and the proposed incoming value.</p>
            <table class="data-table preview-diff-table">
                <colgroup>
                    <col class="col-attribute" />
                    <col class="col-source" />
                    <col class="col-status" />
                    <col class="col-current" />
                    <col class="col-proposed" />
                </colgroup>
                <thead>
                    <tr>
                        <th>Attribute</th>
                        <th>Source</th>
                        <th>Status</th>
                        <th>Current</th>
                        <th>Proposed</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.Preview.DiffRows)
                {
                    <tr class="diff-row @(row.Changed ? "changed" : "same")">
                        <td>@row.Attribute</td>
                        <td class="source-cell">
                            <span class="source-path" title="@(row.Source ?? "-")" tabindex="0">@(row.Source ?? "-")</span>
                        </td>
                        <td>
                            <span class="diff-status @(row.Changed ? "changed" : "same")">
                                @(row.Changed ? "Changed" : "Unchanged")
                            </span>
                        </td>
                        <td class="before"><span>@row.Before</span></td>
                        <td class="after"><span>@row.After</span></td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </section>

    <section class="panel-grid">
        <article class="panel">
            <h2>Resolved SF Attributes</h2>
            @if (resolvedAttributes.Length == 0)
            {
                <p class="muted">No populated SuccessFactors attributes were captured.</p>
            }
            else
            {
                <p class="muted">Showing @resolvedAttributes.Length populated values parsed from SuccessFactors.</p>
                <table class="data-table compact">
                    <thead>
                        <tr>
                            <th>Attribute</th>
                            <th>Value</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var row in resolvedAttributes)
                    {
                        <tr>
                            <td>@row.Attribute</td>
                            <td>@row.Value</td>
                        </tr>
                    }
                    </tbody>
                </table>
            }
        </article>

        <article class="panel">
            <h2>Raw Source Paths</h2>
            @if (sourcePathAttributes.Length == 0)
            {
                <p class="muted">No raw source-path aliases were captured.</p>
            }
            else
            {
                <p class="muted">These rows expose the concrete source paths available for mapping and query work.</p>
                <table class="data-table compact preview-source-table">
                    <colgroup>
                        <col class="col-source-path" />
                        <col class="col-source-value" />
                    </colgroup>
                    <thead>
                        <tr>
                            <th>Source Path</th>
                            <th>Value</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var row in sourcePathAttributes)
                    {
                        <tr>
                            <td><span class="source-path" title="@row.Attribute" tabindex="0">@row.Attribute</span></td>
                            <td><span class="source-value" title="@row.Value" tabindex="0">@row.Value</span></td>
                        </tr>
                    }
                    </tbody>
                </table>
            }
        </article>
    </section>

    <section class="panel">
        <h2>Preview Entries</h2>
        <div class="entry-list">
        @foreach (var entry in Model.Preview.Entries)
        {
            <article class="entry-card">
                <header class="entry-head">
                    <div>
                        <h3>@entry.Bucket</h3>
                    </div>
                </header>
                <pre class="json-block">@entry.Item.GetRawText()</pre>
            </article>
        }
        </div>
    </section>
}

<script>
    (function () {
        var states = [
            {
                form: document.querySelector("[data-worker-lookup-form]"),
                button: document.querySelector("[data-worker-lookup-button]"),
                label: "Looking up..."
            },
            {
                form: document.querySelector("[data-worker-apply-form]"),
                button: document.querySelector("[data-worker-apply-button]"),
                label: "Applying..."
            }
        ];

        states.forEach(function (state) {
            if (!state.form || !state.button) {
                return;
            }

            state.form.addEventListener("submit", function () {
                state.button.disabled = true;
                state.button.classList.add("is-loading");
                state.button.setAttribute("aria-busy", "true");

                var label = state.button.querySelector(".button-label");
                if (label) {
                    label.textContent = state.label;
                }
            });
        });
    })();
</script>

@functions {
    private static string DisplayBool(bool? value) => value.HasValue ? (value.Value ? "Yes" : "No") : "Unknown";

    private static bool IsPathLikeAttribute(string attribute) =>
        attribute.Contains('[') || attribute.Contains('.');
}
