@page "{runId}"
@model SyncFactors.Api.Pages.Runs.DetailModel
@{
    ViewData["Title"] = "Run Detail";
}

@if (Model.Run is null)
{
    <p class="muted">Run not found.</p>
    return;
}

<section class="hero hero-compact">
    <div>
        <p class="eyebrow">Run Detail</p>
        <h1>@Model.Run.Run.RunId</h1>
        <p class="lede">@Model.Run.Run.Mode · @Model.Run.Run.SyncScope · @Model.Run.Run.Status · @(Model.Run.Run.DryRun ? "Dry Run" : "Live Run")</p>
    </div>
    <div class="hero-actions">
        <a class="link-button" asp-page="/Index">Back to dashboard</a>
    </div>
</section>

<section class="panel-grid">
    <article class="panel">
        <h2>Summary</h2>
        <dl class="kv">
            <div><dt>Started</dt><dd>@Model.Run.Run.StartedAt.ToString("u")</dd></div>
            <div><dt>Completed</dt><dd>@(Model.Run.Run.CompletedAt?.ToString("u") ?? "Unknown")</dd></div>
            <div><dt>Artifact</dt><dd>@Model.Run.Run.ArtifactType</dd></div>
            <div><dt>Scope</dt><dd>@Model.Run.Run.SyncScope</dd></div>
            <div><dt>Trigger</dt><dd>@Model.Run.Run.RunTrigger</dd></div>
            <div><dt>Requested By</dt><dd>@(Model.Run.Run.RequestedBy ?? "n/a")</dd></div>
            <div><dt>Status</dt><dd><span class="badge @StatusClass(Model.Run.Run.Status)">@Model.Run.Run.Status</span></dd></div>
            <div><dt>Processed</dt><dd>@Model.Run.Run.ProcessedWorkers</dd></div>
            <div><dt>Total</dt><dd>@Model.Run.Run.TotalWorkers</dd></div>
        </dl>
    </article>

    <article class="panel">
        <h2>Bucket Counts</h2>
        <div class="bucket-grid">
        @foreach (var bucket in Model.Run.BucketCounts)
        {
            <a class="bucket-card" asp-page="/Runs/Detail" asp-route-runId="@Model.Run.Run.RunId" asp-route-bucket="@bucket.Key">
                <span class="bucket-name">@bucket.Key</span>
                <strong>@bucket.Value</strong>
            </a>
        }
        </div>
    </article>
</section>

<section class="panel">
    <h2>Filters</h2>
    <form method="get" class="filters">
        <input type="hidden" name="runId" value="@Model.Run.Run.RunId" />
        <label>
            <span>Worker search</span>
            <input type="text" name="workerId" value="@Model.WorkerId" placeholder="worker id or samAccountName" />
        </label>
        <label class="filter-search">
            <span>Text search</span>
            <input type="text" name="filter" value="@Model.Filter" placeholder="reason, reviewCaseType, raw entry text..." />
        </label>
        <input type="hidden" name="pageNumber" value="1" />
        <div class="filter-actions">
            <button type="submit">Apply</button>
            <a class="link-button" asp-page="/Runs/Detail" asp-route-runId="@Model.Run.Run.RunId">Clear</a>
        </div>
    </form>
    <div class="bucket-chip-row">
        <a class="bucket-card @(string.IsNullOrWhiteSpace(Model.Bucket) ? "active" : null)" asp-page="/Runs/Detail" asp-route-runId="@Model.Run.Run.RunId" asp-route-workerId="@Model.WorkerId" asp-route-filter="@Model.Filter" asp-route-pageNumber="1">All buckets</a>
        @foreach (var bucket in Model.AvailableBuckets)
        {
            <a class="bucket-card @(string.Equals(Model.Bucket, bucket, StringComparison.Ordinal) ? "active" : null)" asp-page="/Runs/Detail" asp-route-runId="@Model.Run.Run.RunId" asp-route-bucket="@bucket" asp-route-workerId="@Model.WorkerId" asp-route-filter="@Model.Filter" asp-route-pageNumber="1">
                <span class="bucket-name">@bucket</span>
                <strong>@Model.Run.BucketCounts[bucket]</strong>
            </a>
        }
    </div>
</section>

<section class="panel">
    <h2>Entries @if (!string.IsNullOrWhiteSpace(Model.Bucket)) { <text>· @Model.Bucket</text> }</h2>
    <p class="muted">Showing page @Model.PageNumber of @Model.TotalPages · @Model.TotalEntries total entries · 15 per page.</p>
    @if (Model.EmploymentStatusTotals.Count > 0)
    {
        <div class="employment-status-summary" aria-label="Employment status totals">
            @foreach (var total in Model.EmploymentStatusTotals)
            {
                var status = Model.DescribeEmploymentStatus(total.Code);
                if (status is null)
                {
                    continue;
                }

                <span class="employment-status-pill @status.ToneCssClass">
                    @status.Label <strong>@total.Count</strong>
                </span>
            }
        </div>
    }
    @if (Model.AttributeTotals.Count > 0)
    {
        <p class="muted">Changed attributes: @string.Join(", ", Model.AttributeTotals.Select(total => $"{total.Attribute}: {total.Count}"))</p>
    }
    @if (Model.Entries.Count == 0)
    {
        <p class="muted">No entries matched this run.</p>
    }
    else
    {
        <div class="entry-list">
        @foreach (var entry in Model.Entries)
        {
            var diagnostics = Model.GetFailureDiagnostics(entry);
            var employmentStatus = Model.GetEmploymentStatus(entry);
            <article class="entry-card">
                <header class="entry-head">
                    <div class="entry-identity">
                        <h3>@entry.BucketLabel</h3>
                        <p class="muted">@entry.WorkerId / @(entry.SamAccountName ?? "n/a")</p>
                        @if (employmentStatus is not null)
                        {
                            <div class="entry-submeta">
                                <span class="employment-status-pill @employmentStatus.ToneCssClass">@employmentStatus.PillText</span>
                                @if (!string.IsNullOrWhiteSpace(employmentStatus.DetailText))
                                {
                                    <span class="entry-submeta-note">@employmentStatus.DetailText</span>
                                }
                            </div>
                        }
                    </div>
                    <div class="entry-meta">
                        <span class="badge neutral">@entry.ChangeCount changes</span>
                    </div>
                </header>
                @if (!string.IsNullOrWhiteSpace(entry.PrimarySummary))
                {
                    <p class="entry-summary">@entry.PrimarySummary</p>
                }
                @if (!string.IsNullOrWhiteSpace(entry.FailureSummary))
                {
                    <p class="callout warn">@entry.FailureSummary</p>
                }
                @if (!string.IsNullOrWhiteSpace(entry.ReviewCaseType) || !string.IsNullOrWhiteSpace(entry.Reason))
                {
                    <dl class="kv preview-meta">
                        <div><dt>Reason</dt><dd>@(entry.Reason ?? "n/a")</dd></div>
                        <div><dt>Review Case</dt><dd>@(entry.ReviewCaseType ?? "n/a")</dd></div>
                    </dl>
                    @if (diagnostics is not null && (diagnostics.Details.Count > 0 || !string.IsNullOrWhiteSpace(diagnostics.Guidance)))
                    {
                        <dl class="kv preview-meta">
                            @foreach (var item in diagnostics.Details)
                            {
                                <div><dt>@item.Label</dt><dd>@item.Value</dd></div>
                            }
                            @if (!string.IsNullOrWhiteSpace(diagnostics.Guidance))
                            {
                                <div><dt>Next Check</dt><dd>@diagnostics.Guidance</dd></div>
                            }
                        </dl>
                    }
                }
                @if (entry.OperationSummary is not null)
                {
                    <p><strong>@entry.OperationSummary.Action</strong>@if (!string.IsNullOrWhiteSpace(entry.OperationSummary.Effect)) { <text> · @entry.OperationSummary.Effect</text> }</p>
                }
                @if (entry.TopChangedAttributes.Count > 0)
                {
                    <p class="muted">Top changes: @string.Join(", ", entry.TopChangedAttributes)</p>
                }
                @if (!string.IsNullOrWhiteSpace(entry.WorkerId))
                {
                    var savedPreviewRunId = GetSavedPreviewRunId(entry);
                    if (!string.IsNullOrWhiteSpace(savedPreviewRunId))
                    {
                        <p><a asp-page="/Preview" asp-route-runId="@savedPreviewRunId">Open saved preview</a></p>
                    }
                    else
                    {
                        <p><a asp-page="/Preview" asp-route-workerId="@entry.WorkerId">Open worker preview</a></p>
                    }
                }
                @if (entry.DiffRows.Count > 0)
                {
                    <table class="data-table compact">
                        <thead>
                            <tr>
                                <th>Attribute</th>
                                <th>Before</th>
                                <th>After</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var diff in entry.DiffRows)
                        {
                            <tr>
                                <td>@diff.Attribute</td>
                                <td>@diff.Before</td>
                                <td>@diff.After</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="muted">No detailed attribute diff was recorded for this entry.</p>
                }
            </article>
        }
        </div>
    }
    @if (Model.TotalPages > 1)
    {
        <div class="filter-actions">
            @if (Model.HasPreviousPage)
            {
                <a class="link-button" asp-page="/Runs/Detail" asp-route-runId="@Model.Run.Run.RunId" asp-route-bucket="@Model.Bucket" asp-route-workerId="@Model.WorkerId" asp-route-filter="@Model.Filter" asp-route-pageNumber="@(Model.PageNumber - 1)">Previous</a>
            }
            @if (Model.HasNextPage)
            {
                <a class="link-button" asp-page="/Runs/Detail" asp-route-runId="@Model.Run.Run.RunId" asp-route-bucket="@Model.Bucket" asp-route-workerId="@Model.WorkerId" asp-route-filter="@Model.Filter" asp-route-pageNumber="@(Model.PageNumber + 1)">Next</a>
            }
        </div>
    }
</section>

@functions {
    private static string StatusClass(string status) =>
        status.ToLowerInvariant() switch
        {
            "succeeded" => "good",
            "failed" => "bad",
            "inprogress" => "warn",
            _ => "neutral",
        };

    private static string? GetSavedPreviewRunId(SyncFactors.Contracts.RunEntry entry)
    {
        if (string.Equals(entry.ArtifactType, "WorkerPreview", StringComparison.OrdinalIgnoreCase))
        {
            return entry.RunId;
        }

        if (entry.Item.ValueKind == System.Text.Json.JsonValueKind.Object &&
            entry.Item.TryGetProperty("sourcePreviewRunId", out var sourcePreviewRunId) &&
            sourcePreviewRunId.ValueKind == System.Text.Json.JsonValueKind.String)
        {
            return sourcePreviewRunId.GetString();
        }

        return null;
    }
}
