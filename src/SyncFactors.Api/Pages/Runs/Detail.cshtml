@page "{runId}"
@model SyncFactors.Api.Pages.Runs.DetailModel
@{
    ViewData["Title"] = "Run Detail";
    var runContext = Model.DescribeRunContext();
    var populationComparison = Model.GetPopulationComparison();
}

@if (Model.Run is null)
{
    <p class="muted">Run not found.</p>
    return;
}

<section class="hero hero-compact">
    <div>
        <p class="eyebrow">Run Detail</p>
        <h1>@Model.Run.Run.RunId</h1>
        <p class="lede">@Model.Run.Run.Mode · @Model.Run.Run.SyncScope · @Model.Run.Run.Status · @(Model.Run.Run.DryRun ? "Dry Run" : "Live Run")</p>
    </div>
    <div class="hero-actions">
        <a class="link-button" asp-page="/Index">Back to dashboard</a>
    </div>
</section>

<section class="panel-grid">
    <article class="panel">
        <h2>Summary</h2>
        <dl class="kv">
            <div><dt>Started</dt><dd>@SyncFactors.Api.UiDateTimeFormatter.FormatDateTime(Model.Run.Run.StartedAt)</dd></div>
            <div><dt>Completed</dt><dd>@SyncFactors.Api.UiDateTimeFormatter.FormatDateTime(Model.Run.Run.CompletedAt, "Unknown")</dd></div>
            <div><dt>Artifact</dt><dd>@Model.Run.Run.ArtifactType</dd></div>
            <div><dt>Scope</dt><dd>@Model.Run.Run.SyncScope</dd></div>
            <div><dt>Trigger</dt><dd>@Model.Run.Run.RunTrigger</dd></div>
            <div><dt>Requested By</dt><dd>@(Model.Run.Run.RequestedBy ?? "n/a")</dd></div>
            <div><dt>Run Type</dt><dd><span class="badge @runContext.ToneCssClass">@runContext.Label</span></dd></div>
            <div><dt>Status</dt><dd><span class="badge @SyncFactors.Api.UiRunFormatting.StatusBadgeTone(Model.Run.Run.Status)">@Model.Run.Run.Status</span></dd></div>
            <div><dt>Processed</dt><dd>@Model.Run.Run.ProcessedWorkers</dd></div>
            <div><dt>Total</dt><dd>@Model.Run.Run.TotalWorkers</dd></div>
        </dl>
        <p class="callout">@runContext.Summary</p>
    </article>

    <article class="panel">
        <h2>Bucket Counts</h2>
        <div class="bucket-grid">
        @foreach (var bucket in Model.Run.BucketCounts)
        {
            <a class="bucket-card" asp-page="/Runs/Detail" asp-route-runId="@Model.Run.Run.RunId" asp-route-bucket="@bucket.Key" asp-route-workerId="@Model.WorkerId" asp-route-filter="@Model.Filter" asp-route-employmentStatus="@Model.EmploymentStatus" asp-fragment="entries">
                <span class="bucket-name">@bucket.Key</span>
                <strong>@bucket.Value</strong>
            </a>
        }
        </div>
    </article>

    @if (populationComparison is not null)
    {
        <article class="panel">
            <div class="panel-heading panel-heading-tight">
                <div>
                    <h2>Population Comparison</h2>
                    <p class="muted">SuccessFactors workers targeting the active OU vs enabled accounts currently in that OU.</p>
                </div>
                <span class="badge @populationComparison.ToneCssClass">@populationComparison.StatusLabel</span>
            </div>
            <div class="metric-strip" aria-label="Population comparison totals">
                <div class="metric-pill">
                    <span>SF active</span>
                    <strong>@populationComparison.SuccessFactorsActive</strong>
                </div>
                <div class="metric-pill">
                    <span>AD enabled</span>
                    <strong>@populationComparison.ActiveDirectoryEnabled</strong>
                </div>
                <div class="metric-pill">
                    <span>Difference</span>
                    <strong>@populationComparison.DifferenceLabel</strong>
                </div>
            </div>
            <p class="muted">@populationComparison.ActiveOuLabel</p>
            <p class="callout">@populationComparison.Summary</p>
        </article>
    }
</section>

<section class="panel">
    <h2>Filters</h2>
    <form method="get" class="filters" asp-page="/Runs/Detail" asp-route-runId="@Model.Run.Run.RunId" asp-fragment="entries">
        <label>
            <span>Worker search</span>
            <input type="text" name="workerId" value="@Model.WorkerId" placeholder="worker id or samAccountName" />
        </label>
        <label class="filter-search">
            <span>Text search</span>
            <input type="text" name="filter" value="@Model.Filter" placeholder="reason, reviewCaseType, raw entry text..." />
        </label>
        <input type="hidden" name="employmentStatus" value="@Model.EmploymentStatus" />
        <input type="hidden" name="pageNumber" value="1" />
        <div class="filter-actions">
            <button type="submit">Apply</button>
            <a class="link-button" asp-page="/Runs/Detail" asp-route-runId="@Model.Run.Run.RunId" asp-fragment="entries">Clear</a>
            <details class="export-menu">
                <summary class="link-button">Export</summary>
                <div class="export-menu-panel">
                    <a class="link-button" asp-page="/Runs/Detail" asp-page-handler="Export" asp-route-runId="@Model.Run.Run.RunId" asp-route-bucket="@Model.Bucket" asp-route-workerId="@Model.WorkerId" asp-route-filter="@Model.Filter">JSON</a>
                    <a class="link-button" asp-page="/Runs/Detail" asp-page-handler="ExportJsonl" asp-route-runId="@Model.Run.Run.RunId" asp-route-bucket="@Model.Bucket" asp-route-workerId="@Model.WorkerId" asp-route-filter="@Model.Filter">JSONL</a>
                    <a class="link-button" asp-page="/Runs/Detail" asp-page-handler="ExportCsv" asp-route-runId="@Model.Run.Run.RunId" asp-route-bucket="@Model.Bucket" asp-route-workerId="@Model.WorkerId" asp-route-filter="@Model.Filter">CSV</a>
                </div>
            </details>
        </div>
    </form>
    <p class="muted">Exports download the full matching set for the active filters, not just the current page. JSONL writes one metadata record first, then one entry record per line. CSV repeats the run and filter context on every row.</p>
    <div class="bucket-chip-row">
        <a class="bucket-card @(string.IsNullOrWhiteSpace(Model.Bucket) ? "active" : null)" asp-page="/Runs/Detail" asp-route-runId="@Model.Run.Run.RunId" asp-route-workerId="@Model.WorkerId" asp-route-filter="@Model.Filter" asp-route-employmentStatus="@Model.EmploymentStatus" asp-route-pageNumber="1" asp-fragment="entries">All buckets</a>
        @foreach (var bucket in Model.AvailableBuckets)
        {
            <a class="bucket-card @(string.Equals(Model.Bucket, bucket, StringComparison.Ordinal) ? "active" : null)" asp-page="/Runs/Detail" asp-route-runId="@Model.Run.Run.RunId" asp-route-bucket="@bucket" asp-route-workerId="@Model.WorkerId" asp-route-filter="@Model.Filter" asp-route-employmentStatus="@Model.EmploymentStatus" asp-route-pageNumber="1" asp-fragment="entries">
                <span class="bucket-name">@bucket</span>
                <strong>@Model.Run.BucketCounts[bucket]</strong>
            </a>
        }
    </div>
</section>

<section class="panel" id="entries">
    <h2>
        Entries
        @if (!string.IsNullOrWhiteSpace(Model.Bucket)) { <text>· @Model.Bucket</text> }
        @if (!string.IsNullOrWhiteSpace(Model.GetEmploymentStatusFilterLabel())) { <text>· @Model.GetEmploymentStatusFilterLabel()</text> }
    </h2>
    <p class="muted">Showing page @Model.PageNumber of @Model.TotalPages · @Model.TotalEntries total entries · 15 per page.</p>
    @if (Model.EmploymentStatusTotals.Count > 0)
    {
        <div class="employment-status-summary" aria-label="Employment status totals">
            <a class="employment-status-pill neutral @(string.IsNullOrWhiteSpace(Model.EmploymentStatus) ? "active" : null)"
               asp-page="/Runs/Detail"
               asp-route-runId="@Model.Run.Run.RunId"
               asp-route-bucket="@Model.Bucket"
               asp-route-workerId="@Model.WorkerId"
               asp-route-filter="@Model.Filter"
               asp-route-employmentStatus=""
               asp-route-pageNumber="1"
               asp-fragment="entries">
                All statuses
            </a>
            @foreach (var total in Model.EmploymentStatusTotals)
            {
                var status = Model.DescribeEmploymentStatus(total.Code);
                if (status is null)
                {
                    continue;
                }

                <a class="employment-status-pill @status.ToneCssClass @(string.Equals(Model.EmploymentStatus, total.Code, StringComparison.OrdinalIgnoreCase) ? "active" : null)"
                   asp-page="/Runs/Detail"
                   asp-route-runId="@Model.Run.Run.RunId"
                   asp-route-bucket="@Model.Bucket"
                   asp-route-workerId="@Model.WorkerId"
                   asp-route-filter="@Model.Filter"
                   asp-route-employmentStatus="@total.Code"
                   asp-route-pageNumber="1"
                   asp-fragment="entries">
                    @status.Label <strong>@total.Count</strong>
                </a>
            }
        </div>
    }
    @if (Model.AttributeTotals.Count > 0)
    {
        <p class="muted">Changed attributes: @string.Join(", ", Model.AttributeTotals.Select(total => $"{total.Attribute}: {total.Count}"))</p>
    }
    @if (Model.Entries.Count == 0)
    {
        <p class="muted">No entries matched this run.</p>
    }
    else
    {
        <div class="entry-list">
        @foreach (var entry in Model.Entries)
        {
            var diagnostics = Model.GetFailureDiagnostics(entry);
            var employmentStatus = Model.GetEmploymentStatus(entry);
            var endDateDisplay = Model.GetEndDateDisplay(entry);
            var primarySummary = Model.GetPrimarySummaryDisplay(entry);
            var failureSummary = Model.GetFailureSummaryDisplay(entry);
            var showReason = Model.ShouldShowReason(entry);
            var showReviewCase = !string.IsNullOrWhiteSpace(entry.ReviewCaseType);
            var execution = Model.DescribeEntryExecution(entry);
            var diagnosticSections = diagnostics is null ? [] : Model.GetFailureDiagnosticSections(diagnostics);
            var manualReviewSections = entry.Bucket == "manualReview" ? Model.GetManualReviewDiagnosticSections(entry) : [];
            var groupedDiagnosticSections = diagnosticSections.Count > 0 ? diagnosticSections : manualReviewSections;
            var decisionSteps = Model.GetProvisioningDecisionSteps(entry);
            <article class="entry-card">
                <header class="entry-head">
                    <div class="entry-identity">
                        <h3>@entry.BucketLabel</h3>
                        <p class="muted">@entry.WorkerId / @(entry.SamAccountName ?? "n/a")</p>
                        @if (employmentStatus is not null || !string.IsNullOrWhiteSpace(endDateDisplay))
                        {
                            <div class="entry-submeta">
                                @if (employmentStatus is not null)
                                {
                                    <span class="employment-status-pill @employmentStatus.ToneCssClass">@employmentStatus.PillText</span>
                                    @if (!string.IsNullOrWhiteSpace(employmentStatus.DetailText))
                                    {
                                        <span class="entry-submeta-note">@employmentStatus.DetailText</span>
                                    }
                                }
                                @if (!string.IsNullOrWhiteSpace(endDateDisplay))
                                {
                                    <span class="entry-submeta-note">End Date @endDateDisplay</span>
                                }
                            </div>
                        }
                    </div>
                    <div class="entry-meta">
                        <span class="badge @execution.ToneCssClass">@execution.Label</span>
                        <span class="badge neutral">@entry.ChangeCount @(entry.ChangeCount == 1 ? "diff" : "diffs")</span>
                    </div>
                </header>
                <p><strong>@execution.Label.</strong> @execution.Summary</p>
                <dl class="kv preview-meta">
                    @foreach (var fact in execution.Facts)
                    {
                        <div><dt>@fact.Label</dt><dd>@fact.Value</dd></div>
                    }
                </dl>
                @if (decisionSteps.Count > 0)
                {
                    <section class="decision-tree">
                        <div class="section-heading">
                            <div>
                                <h4>Provisioning Decision Tree</h4>
                                <p class="muted">Each planner branch that decided whether this worker should be provisioned, updated, skipped, or held for review.</p>
                            </div>
                            <span class="badge neutral">@decisionSteps.Count steps</span>
                        </div>
                        <ol class="decision-tree-list">
                            @foreach (var step in decisionSteps)
                            {
                                <li class="decision-step" data-decision-tone="@step.Tone">
                                    <div class="decision-step-head">
                                        <strong>@step.Step</strong>
                                        <span class="badge @step.Tone">@step.Outcome</span>
                                    </div>
                                    <p>@step.Detail</p>
                                </li>
                            }
                        </ol>
                    </section>
                }
                @if (!string.IsNullOrWhiteSpace(primarySummary))
                {
                    <p class="entry-summary">@primarySummary</p>
                }
                @if (!string.IsNullOrWhiteSpace(failureSummary))
                {
                    <p class="callout warn">@failureSummary</p>
                }
                @if (groupedDiagnosticSections.Count > 0)
                {
                    <div class="preview-inspector-grid failure-inspector-grid">
                        @foreach (var diagnosticSection in groupedDiagnosticSections)
                        {
                            <article class="preview-inspector-card failure-inspector-card" data-tone="@diagnosticSection.ToneCssClass">
                                <div class="preview-inspector-head">
                                    <div>
                                        <h2>@diagnosticSection.Title</h2>
                                        <p class="muted">@diagnosticSection.Summary</p>
                                    </div>
                                </div>
                                <dl class="kv preview-meta failure-inspector-meta">
                                    @foreach (var item in diagnosticSection.Items)
                                    {
                                        <div><dt>@item.Label</dt><dd>@item.Value</dd></div>
                                    }
                                </dl>
                            </article>
                        }
                    </div>
                }
                @if (showReason || showReviewCase)
                {
                    <dl class="kv preview-meta">
                        @if (showReason)
                        {
                            <div><dt>Reason</dt><dd>@entry.Reason</dd></div>
                        }
                        @if (showReviewCase)
                        {
                            <div><dt>Review Case</dt><dd>@entry.ReviewCaseType</dd></div>
                        }
                    </dl>
                }
                @if (diagnostics is not null &&
                     groupedDiagnosticSections.Count == 0 &&
                     (diagnostics.Details.Count > 0 || !string.IsNullOrWhiteSpace(diagnostics.Guidance)))
                {
                    <dl class="kv preview-meta">
                        @foreach (var item in diagnostics.Details)
                        {
                            <div><dt>@item.Label</dt><dd>@item.Value</dd></div>
                        }
                        @if (!string.IsNullOrWhiteSpace(diagnostics.Guidance))
                        {
                            <div><dt>Next Check</dt><dd>@diagnostics.Guidance</dd></div>
                        }
                    </dl>
                }
                @if (entry.OperationSummary is not null)
                {
                    <p><strong>@entry.OperationSummary.Action</strong>@if (!string.IsNullOrWhiteSpace(entry.OperationSummary.Effect)) { <text> · @entry.OperationSummary.Effect</text> }</p>
                }
                @if (entry.TopChangedAttributes.Count > 0)
                {
                    <p class="muted">Top changes: @string.Join(", ", entry.TopChangedAttributes)</p>
                }
                @if (!string.IsNullOrWhiteSpace(entry.WorkerId))
                {
                    var savedPreviewRunId = GetSavedPreviewRunId(entry);
                    if (!string.IsNullOrWhiteSpace(savedPreviewRunId))
                    {
                        <p><a asp-page="/Preview" asp-route-runId="@savedPreviewRunId">Open saved preview</a></p>
                    }
                    else
                    {
                        <p><a asp-page="/Preview" asp-route-workerId="@entry.WorkerId">Open worker preview</a></p>
                    }
                }
                @if (entry.DiffRows.Count > 0)
                {
                    <table class="data-table compact">
                        <thead>
                            <tr>
                                <th>Attribute</th>
                                <th>Before</th>
                                <th>After</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var diff in entry.DiffRows)
                        {
                            <tr>
                                <td>@diff.Attribute</td>
                                <td>@diff.Before</td>
                                <td>@diff.After</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="muted">No detailed attribute diff was recorded for this entry.</p>
                }
            </article>
        }
        </div>
    }
    @if (Model.TotalPages > 1)
    {
        <div class="filter-actions">
            @if (Model.HasPreviousPage)
            {
                <a class="link-button" asp-page="/Runs/Detail" asp-route-runId="@Model.Run.Run.RunId" asp-route-bucket="@Model.Bucket" asp-route-workerId="@Model.WorkerId" asp-route-filter="@Model.Filter" asp-route-employmentStatus="@Model.EmploymentStatus" asp-route-pageNumber="@(Model.PageNumber - 1)" asp-fragment="entries">Previous</a>
            }
            @if (Model.HasNextPage)
            {
                <a class="link-button" asp-page="/Runs/Detail" asp-route-runId="@Model.Run.Run.RunId" asp-route-bucket="@Model.Bucket" asp-route-workerId="@Model.WorkerId" asp-route-filter="@Model.Filter" asp-route-employmentStatus="@Model.EmploymentStatus" asp-route-pageNumber="@(Model.PageNumber + 1)" asp-fragment="entries">Next</a>
            }
        </div>
    }
</section>

@functions {
    private static string? GetSavedPreviewRunId(SyncFactors.Contracts.RunEntry entry)
    {
        if (string.Equals(entry.ArtifactType, "WorkerPreview", StringComparison.OrdinalIgnoreCase))
        {
            return entry.RunId;
        }

        if (entry.Item.ValueKind == System.Text.Json.JsonValueKind.Object &&
            entry.Item.TryGetProperty("sourcePreviewRunId", out var sourcePreviewRunId) &&
            sourcePreviewRunId.ValueKind == System.Text.Json.JsonValueKind.String)
        {
            return sourcePreviewRunId.GetString();
        }

        return null;
    }
}
