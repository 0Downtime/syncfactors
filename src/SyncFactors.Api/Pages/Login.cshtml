@page
@model SyncFactors.Api.Pages.LoginModel
@{
    ViewData["Title"] = "Login";
}

<section class="hero hero-compact auth-hero">
    <div>
        <p class="eyebrow">Secure Access</p>
        <h1>Sign in</h1>
        <p class="lede">Use enterprise SSO where configured. Local sign-in is reserved for break-glass administration.</p>
    </div>
</section>

<section class="panel auth-panel">
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <p class="callout danger">@Model.ErrorMessage</p>
    }

    @if (Model.IsOidcEnabled)
    {
        <form method="post" asp-page-handler="Sso" class="filters auth-form">
            <input type="hidden" asp-for="ReturnUrl" />
            <div class="filter-actions">
                <button type="submit">Sign in with SSO</button>
            </div>
        </form>
    }

    @if (Model.IsLocalLoginEnabled)
    {
        <form method="post" class="filters auth-form">
            <input type="hidden" asp-for="ReturnUrl" />
            <label>
                <span>Username</span>
                <input asp-for="Username" type="text" autocomplete="username" />
            </label>
            <label>
                <span>Password</span>
                <input asp-for="Password" type="password" autocomplete="current-password" />
            </label>
            @if (Model.CanRememberMe)
            {
                <label class="filter-check auth-remember">
                    <span>Remember my login</span>
                    <input asp-for="RememberMe" type="checkbox" />
                </label>
            }
            <div class="filter-actions">
                <button type="submit">Use break-glass sign-in</button>
            </div>
        </form>
    }
</section>
