<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SyncFactors</title>
    <script src="~/js/theme-init.js" asp-append-version="true"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="shell">
        <header class="topbar">
            <div class="topbar-brand">
                <div class="brand-row">
                    <a class="brand" asp-page="/Index" aria-label="SyncFactors home">
                        <img class="brand-logo brand-logo-light" src="~/images/syncfactors-logo-black.png" alt="SyncFactors" />
                        <img class="brand-logo brand-logo-dark" src="~/images/syncfactors-logo-white.png" alt="SyncFactors" />
                    </a>
                </div>
            </div>
            <div class="topbar-actions">
                <nav class="nav">
                    <a asp-page="/Index">Dashboard</a>
                    <a asp-page="/Sync">Sync</a>
                    <a asp-page="/Preview">Worker Preview</a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-page="/Admin/Users">Users</a>
                    }
                </nav>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    var role = User.IsInRole("BreakGlassAdmin")
                        ? "BreakGlassAdmin"
                        : User.IsInRole("Admin")
                            ? "Admin"
                            : User.IsInRole("Operator")
                                ? "Operator"
                                : User.IsInRole("Viewer")
                                    ? "Viewer"
                                    : "Unknown";
                    <div class="auth-actions">
                        <a class="link-button" asp-page="/Logout">Logout</a>
                        <div class="muted auth-user">
                            <span>Signed in as <strong>@User.Identity.Name</strong></span>
                            <span class="auth-role">Role: @role</span>
                        </div>
                    </div>
                }
                <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle dark mode" aria-pressed="false">
                    <span class="theme-toggle-option theme-toggle-option-light" aria-hidden="true">☀</span>
                    <span class="theme-toggle-track" aria-hidden="true">
                        <span class="theme-toggle-thumb"></span>
                    </span>
                    <span class="theme-toggle-option theme-toggle-option-dark" aria-hidden="true">☾</span>
                </button>
            </div>
        </header>
        <main class="content">
            @RenderBody()
        </main>
    </div>
    <script src="~/dist/site.js" asp-append-version="true"></script>
</body>
</html>
