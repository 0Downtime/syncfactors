@using System.Reflection
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment HostEnvironment
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0078d4" />
    <title>@ViewData["Title"] - SyncFactors</title>
    <script src="~/js/theme-init.js" asp-append-version="true"></script>
    <link rel="icon" type="image/x-icon" href="~/images/favicon.ico" asp-append-version="true" />
    <link rel="icon" type="image/png" sizes="32x32" href="~/images/favicon-32.png" asp-append-version="true" />
    <link rel="apple-touch-icon" sizes="180x180" href="~/images/apple-touch-icon.png" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
@{
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? string.Empty;
    var currentPageToken = currentPage
        .Trim('/')
        .Replace("/", "-", StringComparison.Ordinal)
        .ToLowerInvariant();
    var isAdmin = User.IsInRole("Admin") || User.IsInRole("BreakGlassAdmin");
    var isDashboardPage = currentPage == "/Index";
    var isSyncPage = currentPage.StartsWith("/Sync", StringComparison.OrdinalIgnoreCase);
    var isPreviewPage = currentPage.StartsWith("/Preview", StringComparison.OrdinalIgnoreCase);
    var isAdminPage = currentPage.StartsWith("/Admin", StringComparison.OrdinalIgnoreCase);
    var isAdminUsersPage = currentPage.StartsWith("/Admin/Users", StringComparison.OrdinalIgnoreCase);
    var isAdminDeletionQueuePage = currentPage.StartsWith("/Admin/DeletionQueue", StringComparison.OrdinalIgnoreCase);
    var isAdminConfigurationPage = currentPage.StartsWith("/Admin/Configuration", StringComparison.OrdinalIgnoreCase);
    var appVersion = typeof(SyncFactors.Api.DashboardOptions).Assembly
        .GetCustomAttribute<AssemblyInformationalVersionAttribute>()?
        .InformationalVersion;
    if (string.IsNullOrWhiteSpace(appVersion))
    {
        appVersion = typeof(SyncFactors.Api.DashboardOptions).Assembly.GetName().Version?.ToString() ?? "unknown";
    }

    var appEnvironment = HostEnvironment.EnvironmentName;
    var showDevelopmentBanner = string.Equals(appEnvironment, "Development", StringComparison.OrdinalIgnoreCase);
}
<body data-page="@currentPageToken">
    <div class="shell">
        <header class="topbar" data-topbar>
            <div class="topbar-brand">
                <div class="brand-row">
                    <a class="brand" asp-page="/Index" aria-label="SyncFactors home">
                        <img class="brand-logo brand-logo-light" src="~/images/syncfactors-logo-black.png" alt="SyncFactors" />
                        <img class="brand-logo brand-logo-dark" src="~/images/syncfactors-logo-white.png" alt="SyncFactors" />
                    </a>
                </div>
            </div>
            <div class="topbar-actions">
                <nav class="nav">
                    <a class="@(isDashboardPage ? "is-active" : null)" asp-page="/Index">Dashboard</a>
                    <a class="@(isSyncPage ? "is-active" : null)" asp-page="/Sync">Sync</a>
                    <a class="@(isPreviewPage ? "is-active" : null)" asp-page="/Preview">Manual Provision</a>
                    @if (isAdmin)
                    {
                        <details class="nav-menu" data-nav-menu>
                            <summary class="@(isAdminPage ? "is-active" : null)">Admin</summary>
                            <div class="nav-menu-panel">
                                <a class="@(isAdminUsersPage ? "is-active" : null)" asp-page="/Admin/Users">Users</a>
                                <a class="@(isAdminDeletionQueuePage ? "is-active" : null)" asp-page="/Admin/DeletionQueue">Deletion Queue</a>
                                <a class="@(isAdminConfigurationPage ? "is-active" : null)" asp-page="/Admin/Configuration">Configuration</a>
                            </div>
                        </details>
                    }
                </nav>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    var role = User.IsInRole("BreakGlassAdmin")
                        ? "BreakGlassAdmin"
                        : User.IsInRole("Admin")
                            ? "Admin"
                            : User.IsInRole("Operator")
                                ? "Operator"
                                : User.IsInRole("Viewer")
                                    ? "Viewer"
                                    : "Unknown";
                    <div class="auth-actions">
                        <a class="link-button" asp-page="/Logout">Logout</a>
                        <div class="muted auth-user">
                            <span>Signed in as <strong>@User.Identity.Name</strong></span>
                            <span class="auth-role">Role: @role</span>
                        </div>
                    </div>
                }
                <div class="theme-toggle" id="theme-toggle" role="group" aria-label="Color mode">
                    <button class="theme-toggle-option" type="button" data-theme-option="system" aria-pressed="false">System</button>
                    <button class="theme-toggle-option" type="button" data-theme-option="light" aria-pressed="false">Light</button>
                    <button class="theme-toggle-option" type="button" data-theme-option="dark" aria-pressed="false">Dark</button>
                </div>
            </div>
        </header>
        <main class="content">
            @RenderBody()
        </main>
        <footer class="app-footer" aria-label="Application version">
            <span>SyncFactors</span>
            <span>v@appVersion</span>
        </footer>
    </div>
    @if (showDevelopmentBanner)
    {
        <div class="environment-corner-banner" role="status" aria-label="Environment and version">
            <strong>@appEnvironment</strong>
            <span>v@appVersion</span>
        </div>
    }
    <div class="toast-region" aria-live="polite" aria-atomic="true" data-toast-region></div>
    <script src="~/dist/site.js" asp-append-version="true"></script>
</body>
</html>
