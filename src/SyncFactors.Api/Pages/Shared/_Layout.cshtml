<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SyncFactors</title>
    <script src="~/js/theme-init.js" asp-append-version="true"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="shell">
        <header class="topbar">
            <div class="topbar-brand">
                <div class="brand-row">
                    <a class="brand" asp-page="/Index">SyncFactors</a>
                    <span class="brand-badge">Portal</span>
                </div>
                <p class="subtitle">Operator dashboard for the .NET 10 rewrite</p>
            </div>
            <div class="topbar-actions">
                <nav class="nav">
                    <a asp-page="/Index">Dashboard</a>
                    <a asp-page="/Sync">Sync</a>
                    <a asp-page="/Preview">Worker Preview</a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-page="/Admin/Users">Users</a>
                    }
                </nav>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="auth-actions">
                        <span class="muted auth-user">Signed in as <strong>@User.Identity.Name</strong></span>
                        <form method="post" asp-page="/Logout">
                            <button type="submit" class="link-button">Logout</button>
                        </form>
                    </div>
                }
                <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle dark mode" aria-pressed="false">
                    <span class="theme-toggle-option theme-toggle-option-light" aria-hidden="true">☀</span>
                    <span class="theme-toggle-track" aria-hidden="true">
                        <span class="theme-toggle-thumb"></span>
                    </span>
                    <span class="theme-toggle-option theme-toggle-option-dark" aria-hidden="true">☾</span>
                </button>
            </div>
        </header>
        <main class="content">
            @RenderBody()
        </main>
    </div>
    <script src="~/js/site.js" asp-append-version="true"></script>
</body>
</html>
