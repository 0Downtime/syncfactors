@page
@model SyncFactors.Api.Pages.Admin.DeletionQueueModel
@{
    ViewData["Title"] = "Deletion Queue";
}

<section class="hero hero-compact">
    <div>
        <p class="eyebrow">Administration</p>
        <h1>Deletion Queue</h1>
        <p class="lede">Review graveyard users who are pending automatic deletion and place reversible holds when a user must stay preserved past retention.</p>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <section class="panel" data-auto-dismiss-ms="5000">
        <p class="callout danger">@Model.ErrorMessage</p>
    </section>
}

@if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
{
    <section class="panel" data-auto-dismiss-ms="5000">
        <p class="callout good">@Model.SuccessMessage</p>
    </section>
}

<section class="panel">
    <h2>Filters</h2>
    <form method="get" class="filters">
        <label class="filter-search">
            <span>Text search</span>
            <input type="text" name="filter" value="@Model.Filter" placeholder="worker id, user, status, distinguished name..." />
        </label>
        <input type="hidden" name="pendingPageNumber" value="1" />
        <input type="hidden" name="heldPageNumber" value="1" />
        <div class="filter-actions">
            <button type="submit">Apply</button>
            <a class="link-button" asp-page="/Admin/DeletionQueue">Clear</a>
        </div>
    </form>
</section>

<section class="panel">
    <div class="section-heading">
        <div>
            <p class="eyebrow">Pending</p>
            <h2>Pending Deletion</h2>
        </div>
    </div>
    <p class="muted">Showing page @Model.PendingPageNumber of @Model.TotalPendingPages · @Model.TotalPendingUsers total records · 25 per page.</p>

    @if (Model.PendingUsers.Count == 0)
    {
        <p class="callout">No graveyard users are currently pending deletion.</p>
    }
    else
    {
        <div class="table-scroll">
            <table class="data-table deletion-queue-table">
                <thead>
                    <tr>
                        <th>Worker ID</th>
                        <th>User</th>
                        <th>Status</th>
                        <th>Anchor Date</th>
                        <th>Due Date</th>
                        <th>Countdown</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var user in Model.PendingUsers)
                {
                    <tr>
                        <td>@user.WorkerId</td>
                        <td>
                            <div class="deletion-queue-user">
                                <strong>@(user.DisplayName ?? user.SamAccountName ?? user.WorkerId)</strong>
                                <span class="muted">@(user.SamAccountName ?? "SAM unavailable")</span>
                            </div>
                        </td>
                        <td><span class="badge @(user.OverdueDays > 0 ? "bad" : user.IsEligibleForDeletion ? "warn" : "neutral")">@Model.FormatStatus(user)</span></td>
                        <td>@SyncFactors.Api.UiDateTimeFormatter.FormatDate(user.AnchorDateUtc)</td>
                        <td>@SyncFactors.Api.UiDateTimeFormatter.FormatDate(user.DueDateUtc)</td>
                        <td>
                            <span class="badge @(user.OverdueDays > 0 ? "bad" : user.IsEligibleForDeletion ? "warn" : "good")">
                                @Model.FormatCountdown(user)
                            </span>
                        </td>
                        <td>
                            <form method="post" asp-page-handler="PlaceHold" asp-route-filter="@Model.Filter" asp-route-pendingPageNumber="@Model.PendingPageNumber" asp-route-heldPageNumber="@Model.HeldPageNumber">
                                <input type="hidden" name="workerId" value="@user.WorkerId" />
                                <button type="submit" class="link-button">Place hold</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <div class="table-pagination">
            <p class="muted">Showing @Model.PendingUsers.Count of @Model.TotalPendingUsers pending records.</p>
            <div class="filter-actions">
                @if (Model.HasPreviousPendingPage)
                {
                    <a class="link-button" asp-page="/Admin/DeletionQueue" asp-route-filter="@Model.Filter" asp-route-pendingPageNumber="@(Model.PendingPageNumber - 1)" asp-route-heldPageNumber="@Model.HeldPageNumber">Previous</a>
                }
                @if (Model.HasNextPendingPage)
                {
                    <a class="link-button" asp-page="/Admin/DeletionQueue" asp-route-filter="@Model.Filter" asp-route-pendingPageNumber="@(Model.PendingPageNumber + 1)" asp-route-heldPageNumber="@Model.HeldPageNumber">Next</a>
                }
            </div>
        </div>
    }
</section>

<section class="panel">
    <div class="section-heading">
        <div>
            <p class="eyebrow">Protected</p>
            <h2>On Hold</h2>
        </div>
    </div>
    <p class="muted">Showing page @Model.HeldPageNumber of @Model.TotalHeldPages · @Model.TotalHeldUsers total records · 25 per page.</p>

    @if (Model.HeldUsers.Count == 0)
    {
        <p class="callout">No graveyard users are currently on hold.</p>
    }
    else
    {
        <div class="table-scroll">
            <table class="data-table deletion-queue-table">
                <thead>
                    <tr>
                        <th>Worker ID</th>
                        <th>User</th>
                        <th>Status</th>
                        <th>Due Date</th>
                        <th>Held Since</th>
                        <th>Held By</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var user in Model.HeldUsers)
                {
                    <tr>
                        <td>@user.WorkerId</td>
                        <td>
                            <div class="deletion-queue-user">
                                <strong>@(user.DisplayName ?? user.SamAccountName ?? user.WorkerId)</strong>
                                <span class="muted">@(user.SamAccountName ?? "SAM unavailable")</span>
                            </div>
                        </td>
                        <td><span class="badge dim">@Model.FormatStatus(user)</span></td>
                        <td>@SyncFactors.Api.UiDateTimeFormatter.FormatDate(user.DueDateUtc)</td>
                        <td>@SyncFactors.Api.UiDateTimeFormatter.FormatDateTime(user.HoldPlacedAtUtc, "Unknown")</td>
                        <td>@(user.HoldPlacedBy ?? "Unknown")</td>
                        <td>
                            <form method="post" asp-page-handler="RemoveHold" asp-route-filter="@Model.Filter" asp-route-pendingPageNumber="@Model.PendingPageNumber" asp-route-heldPageNumber="@Model.HeldPageNumber">
                                <input type="hidden" name="workerId" value="@user.WorkerId" />
                                <button type="submit" class="link-button">Remove hold</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <div class="table-pagination">
            <p class="muted">Showing @Model.HeldUsers.Count of @Model.TotalHeldUsers held records.</p>
            <div class="filter-actions">
                @if (Model.HasPreviousHeldPage)
                {
                    <a class="link-button" asp-page="/Admin/DeletionQueue" asp-route-filter="@Model.Filter" asp-route-pendingPageNumber="@Model.PendingPageNumber" asp-route-heldPageNumber="@(Model.HeldPageNumber - 1)">Previous</a>
                }
                @if (Model.HasNextHeldPage)
                {
                    <a class="link-button" asp-page="/Admin/DeletionQueue" asp-route-filter="@Model.Filter" asp-route-pendingPageNumber="@Model.PendingPageNumber" asp-route-heldPageNumber="@(Model.HeldPageNumber + 1)">Next</a>
                }
            </div>
        </div>
    }
</section>
