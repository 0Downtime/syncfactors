@page
@model SyncFactors.Api.Pages.Admin.UsersModel
@using SyncFactors.Infrastructure
@{
    ViewData["Title"] = "Users";
}

<section class="hero hero-compact">
    <div>
        <p class="eyebrow">Administration</p>
        <h1>User Access</h1>
        <p class="lede">@Model.AccountManagementDescription</p>
        <p><span class="badge @Model.AuthenticationModeBadgeClass">@Model.AuthenticationModeLabel</span></p>
        <p class="callout">@Model.AuthenticationModeDescription</p>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <section class="panel" data-auto-dismiss-ms="5000">
        <p class="callout danger">@Model.ErrorMessage</p>
    </section>
}

@if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
{
    <section class="panel" data-auto-dismiss-ms="5000">
        <p class="callout good">@Model.SuccessMessage</p>
    </section>
}

@if (Model.IsOidcAccessOverviewEnabled)
{
    <section class="panel">
        <div class="section-heading">
            <div>
                <p class="eyebrow">OpenID Connect</p>
                <h2>SSO Groups</h2>
                <p class="muted">Accounts appear after their first successful SSO login.</p>
                <p class="muted">Recorded accounts may remain visible after group removal; IdP group membership is what governs current access.</p>
            </div>
        </div>
        <div class="table-scroll">
            <table class="data-table oidc-group-table">
                <thead>
                    <tr>
                        <th>Group</th>
                        <th>Grants</th>
                        <th>Accounts</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var group in Model.OidcGroups)
                {
                    <tr>
                        <td>@group.GroupName</td>
                        <td><span class="badge @Model.AccessBadgeClass(group.AccessLevel)">@group.AccessLevel</span></td>
                        <td>
                            @if (group.Members.Count == 0)
                            {
                                <span class="muted">No recorded logins</span>
                            }
                            else
                            {
                                <div class="oidc-member-list">
                                @foreach (var member in group.Members)
                                {
                                    <div class="oidc-member">
                                        <div>
                                            <strong>@member.Username</strong>
                                            @if (!string.IsNullOrWhiteSpace(member.DisplayName))
                                            {
                                                <span class="muted">@member.DisplayName</span>
                                            }
                                        </div>
                                        <span class="badge @Model.AccessBadgeClass(member.AccessLevel)">@member.AccessLevel</span>
                                        <span class="muted">@SyncFactors.Api.UiDateTimeFormatter.FormatDateTime(member.LastLoginAt)</span>
                                    </div>
                                }
                                </div>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <div class="role-permission-summary">
            <h3>Role Permissions</h3>
            <div class="table-scroll">
                <table class="data-table compact">
                    <thead>
                        <tr>
                            <th>Role</th>
                            <th>Access</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><span class="badge neutral">Viewer</span></td>
                            <td>Can view dashboards, run history, worker previews, status, and health information.</td>
                        </tr>
                        <tr>
                            <td><span class="badge good">Operator</span></td>
                            <td>Includes Viewer access, plus can run syncs, generate previews, apply previews, cancel runs, and queue delete-all operations.</td>
                        </tr>
                        <tr>
                            <td><span class="badge info">Admin</span></td>
                            <td>Includes Operator access, plus can manage configuration, schedules, deletion queue holds, local users, and SSO access visibility.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </section>
}

@if (Model.IsLocalUserManagementEnabled)
{
    <section class="panel-grid admin-user-grid">
        <article class="panel">
            <h2>Create User</h2>
            <form method="post" asp-page-handler="Create" class="filters admin-user-form">
                <label>
                    <span>Username</span>
                    <input asp-for="CreateUsername" type="text" autocomplete="off" />
                </label>
                <label>
                    <span>Password</span>
                    <input asp-for="CreatePassword" type="password" autocomplete="new-password" />
                </label>
                <label>
                    <span>Confirm password</span>
                    <input asp-for="CreatePasswordConfirmation" type="password" autocomplete="new-password" />
                </label>
                <label>
                    <span>Role</span>
                    <select asp-for="CreateRole">
                        <option value="@SecurityRoles.Viewer">Viewer</option>
                        <option value="@SecurityRoles.Operator">Operator</option>
                        <option value="@SecurityRoles.Admin">Admin</option>
                    </select>
                </label>
                <div class="filter-actions">
                    <button type="submit">Create user</button>
                </div>
            </form>
        </article>

        <article class="panel">
            <h2>Security Notes</h2>
            <div class="risk-list">
                <p class="callout">Passwords are stored as one-way hashes.</p>
                <p class="callout">New passwords must be at least 12 characters and include uppercase, lowercase, and numeric characters.</p>
                <p class="callout warn">This page cannot disable or delete your own account, and it will not remove the last active admin.</p>
            </div>
        </article>
    </section>

    <section class="panel">
        <div class="section-heading">
            <div>
                <p class="eyebrow">Directory</p>
                <h2>Local Users</h2>
            </div>
        </div>
        <div class="table-scroll">
            <table class="data-table admin-user-table">
                <thead>
                    <tr>
                        <th>Username</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th>Last Login</th>
                        <th>Reset Password</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var user in Model.Users)
                {
                    <tr>
                        <td>@user.Username</td>
                        <td>
                            <form method="post" asp-page-handler="ChangeRole" class="admin-user-role-form">
                                <input type="hidden" name="userId" value="@user.UserId" />
                                <span class="badge @Model.AccessBadgeClass(user.Role)">@user.Role</span>
                                <select name="role" aria-label="Role for @user.Username">
                                    <option value="@SecurityRoles.Viewer" selected="@(string.Equals(user.Role, SecurityRoles.Viewer, StringComparison.OrdinalIgnoreCase))">Viewer</option>
                                    <option value="@SecurityRoles.Operator" selected="@(string.Equals(user.Role, SecurityRoles.Operator, StringComparison.OrdinalIgnoreCase))">Operator</option>
                                    <option value="@SecurityRoles.Admin" selected="@(string.Equals(user.Role, SecurityRoles.Admin, StringComparison.OrdinalIgnoreCase))">Admin</option>
                                </select>
                                <button type="submit" class="link-button admin-user-compact-button">Set role</button>
                            </form>
                        </td>
                        <td>
                            <span class="badge @(user.IsActive ? "good" : "dim")">@(user.IsActive ? "Active" : "Inactive")</span>
                        </td>
                        <td>@SyncFactors.Api.UiDateTimeFormatter.FormatDateTime(user.CreatedAt)</td>
                        <td>@SyncFactors.Api.UiDateTimeFormatter.FormatDateTime(user.LastLoginAt, "Never")</td>
                        <td>
                            <form method="post" asp-page-handler="ResetPassword" class="admin-user-inline-form">
                                <input type="hidden" name="userId" value="@user.UserId" />
                                <label>
                                    <span class="sr-only">New password for @user.Username</span>
                                    <input type="password" name="newPassword" autocomplete="new-password" placeholder="New" />
                                </label>
                                <label>
                                    <span class="sr-only">Confirm password for @user.Username</span>
                                    <input type="password" name="confirmPassword" autocomplete="new-password" placeholder="Confirm" />
                                </label>
                                <button type="submit" class="admin-user-compact-button">Reset</button>
                            </form>
                        </td>
                        <td>
                            <div class="admin-user-actions">
                                <form method="post" asp-page-handler="ToggleActive">
                                    <input type="hidden" name="userId" value="@user.UserId" />
                                    <input type="hidden" name="makeActive" value="@(user.IsActive ? "false" : "true")" />
                                    <button type="submit" class="link-button admin-user-compact-button">@(user.IsActive ? "Disable" : "Enable")</button>
                                </form>
                                <form method="post" asp-page-handler="Delete">
                                    <input type="hidden" name="userId" value="@user.UserId" />
                                    <button type="submit" class="link-button danger-button admin-user-compact-button">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </section>
}
else
{
    <section class="panel-grid admin-user-grid">
        <article class="panel">
            <h2>SSO-Managed Access</h2>
            <div class="sso-access-box">
                <p class="sso-access-lead">User sign-in is managed by your enterprise SSO provider for this deployment.</p>
                <ul class="sso-access-list">
                    <li>Create, disable, and delete accounts in your identity provider, not in this portal.</li>
                    <li>Admin, operator, and viewer access should come from your configured group mappings.</li>
                </ul>
            </div>
        </article>

        <article class="panel">
            <h2>Security Notes</h2>
            <div class="risk-list">
                <p class="callout">Break-glass local passwords are disabled while this portal is in SSO-only mode.</p>
                <p class="callout warn">If you need emergency local access, switch the deployment to hybrid mode and provision a break-glass admin.</p>
            </div>
        </article>
    </section>
}
