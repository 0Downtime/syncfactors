@page
@model SyncFactors.Api.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
    const int initialRunsPageSize = 25;
    var initialRuns = Model.Runs.Take(initialRunsPageSize).ToList();
    var initialRunsEnd = Math.Min(initialRunsPageSize, Model.Runs.Count);
    var initialHasMoreRuns = Model.Runs.Count > initialRunsPageSize;
}

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <section class="panel" data-auto-dismiss-ms="5000">
        <p class="callout danger">@Model.ErrorMessage</p>
    </section>
}

@if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
{
    <section class="panel" data-auto-dismiss-ms="5000">
        <p class="callout good">@Model.SuccessMessage</p>
    </section>
}

@if (Model.RequiresAttention)
{
    <section class="panel">
        <p class="callout danger" data-dashboard-attention>@(Model.AttentionMessage ?? "Operator attention is required.")</p>
    </section>
}

<section class="panel-grid dashboard-grid">
    <article class="panel dashboard-rail">
        <div class="panel-heading panel-heading-tight">
            <h2>Status</h2>
            <section class="connection-summary-card connection-summary-card-inline" aria-label="Dependency health summary" data-connection-health data-health-probes-enabled="@(Model.HealthProbesEnabled ? "true" : "false")" data-health-probe-interval-ms="@(Model.HealthProbeIntervalSeconds * 1000)">
                <details class="connection-health-menu">
                    <summary class="connection-health-button">
                        <span class="badge @(Model.HealthProbesEnabled ? "neutral" : "dim")" data-health-overall-badge>Connection Health</span>
                        <span class="connection-health-button-caret" aria-hidden="true"></span>
                    </summary>
                    <ul class="connection-health-dropdown" data-health-list>
                        @foreach (var dependency in new[] { "SuccessFactors", "Active Directory", "Worker Service", "SQLite" })
                        {
                            var summary = Model.HealthProbesEnabled ? "Probe pending." : "Dashboard probing is turned off.";
                            var detail = Model.HealthProbesEnabled
                                ? "The dashboard will run this check after the page settles."
                                : "Enable dashboard health probes to run this dependency check.";
                            <li class="connection-health-item" title="@($"{dependency}: {summary} {detail}")">
                                <div class="connection-health-item-head">
                                    <span class="connection-health-item-name">@dependency</span>
                                    <span class="badge @(Model.HealthProbesEnabled ? "neutral" : "dim")">@(Model.HealthProbesEnabled ? "Waiting" : "Disabled")</span>
                                </div>
                                <p class="connection-health-item-summary">@summary</p>
                            </li>
                        }
                    </ul>
                </details>
            </section>
        </div>
        <section class="dashboard-schedule-widget" aria-label="Next scheduled sync">
            <div class="dashboard-schedule-head">
                <div>
                    <p class="eyebrow">Next Scheduled Sync</p>
                    <p class="dashboard-schedule-title" data-dashboard-schedule-title>@(Model.Schedule.Enabled ? "Recurring schedule is active" : "Recurring schedule is paused")</p>
                </div>
                <span class="badge @(Model.Schedule.Enabled ? "good" : "dim")" data-dashboard-schedule-badge>@(Model.Schedule.Enabled ? "Enabled" : "Paused")</span>
            </div>
            <div class="dashboard-schedule-body">
                <div class="dashboard-schedule-countdown" data-dashboard-schedule-countdown style="--ring-progress: @(Model.Schedule.NextRunAt.HasValue ? "0.82turn" : "0turn");">
                    <div class="dashboard-schedule-countdown-copy">
                        <strong data-dashboard-schedule-countdown-value>@(Model.Schedule.NextRunAt.HasValue ? "Pending" : "Idle")</strong>
                    </div>
                </div>
                <dl class="kv dashboard-schedule-kv">
                    <div><dt>Next Run</dt><dd data-dashboard-schedule-next-run-at="@(Model.Schedule.NextRunAt?.ToString("o") ?? string.Empty)">@SyncFactors.Api.UiDateTimeFormatter.FormatDateTime(Model.Schedule.NextRunAt, "Not scheduled")</dd></div>
                    <div><dt>Interval</dt><dd data-dashboard-schedule-interval>@(Model.Schedule.Enabled ? $"{Model.Schedule.IntervalMinutes} minutes" : "Not scheduled")</dd></div>
                    <div><dt>Last Scheduled</dt><dd data-dashboard-schedule-last-run>@SyncFactors.Api.UiDateTimeFormatter.FormatDateTime(Model.Schedule.LastScheduledRunAt, "Not scheduled")</dd></div>
                </dl>
            </div>
        </section>
        <section class="dashboard-status-signal" data-dashboard-signal data-signal-state="@StatusVisualState(Model.Status)" aria-label="Runtime signal">
            <div class="dashboard-status-visual" aria-hidden="true">
                <span class="dashboard-status-orbit dashboard-status-orbit-outer"></span>
                <span class="dashboard-status-orbit dashboard-status-orbit-inner"></span>
                <span class="dashboard-status-core"></span>
            </div>
            <div class="dashboard-status-copy">
                <p class="eyebrow">Runtime Signal</p>
                <p class="dashboard-status-line" data-status-line>@StatusLine(Model.Status)</p>
                <p class="dashboard-status-caption muted" data-status-caption>@StatusCaption(Model.Status)</p>
            </div>
        </section>
        <section class="dashboard-progress" data-progress-state="@ProgressVisualState(Model.Status)" aria-label="Run progress">
            <div class="dashboard-progress-head">
                <p class="eyebrow">Worker Progress</p>
                <p class="dashboard-progress-value" data-progress-caption>@ProgressLabel(Model.Status)</p>
            </div>
            <div class="dashboard-progress-track" aria-hidden="true">
                <span class="dashboard-progress-fill" data-progress-fill style="width: @(ProgressFillWidth(Model.Status))%;"></span>
            </div>
            <p class="muted dashboard-progress-copy" data-progress-copy>@ProgressCopy(Model.Status)</p>
        </section>
        <dl class="kv" data-dashboard-status>
            <div><dt>Status</dt><dd data-status-value>@SyncFactors.Api.UiRunFormatting.DisplayLabel(Model.Status.Status)</dd></div>
            <div><dt>Stage</dt><dd data-stage-value>@SyncFactors.Api.UiRunFormatting.DisplayLabel(Model.Status.Stage)</dd></div>
            <div><dt>Run</dt><dd data-run-id-value>@SyncFactors.Api.UiRunFormatting.RuntimeDisplayName(Model.Status)</dd></div>
            <div><dt>Worker</dt><dd data-worker-value>@(Model.Status.CurrentWorkerId ?? "None")</dd></div>
            <div><dt>Progress</dt><dd data-progress-value>@Model.Status.ProcessedWorkers / @Model.Status.TotalWorkers</dd></div>
            <div><dt>Last Action</dt><dd data-last-action-value>@(Model.Status.LastAction ?? "None")</dd></div>
            <div><dt>Started</dt><dd data-started-at-value>@SyncFactors.Api.UiDateTimeFormatter.FormatDateTime(Model.Status.StartedAt, "Not started")</dd></div>
            <div><dt>Completed</dt><dd data-completed-at-value>@SyncFactors.Api.UiDateTimeFormatter.FormatDateTime(Model.Status.CompletedAt, "Not completed")</dd></div>
            <div><dt>Last Updated</dt><dd data-last-updated-value>@SyncFactors.Api.UiDateTimeFormatter.FormatDateTime(Model.Status.LastUpdatedAt)</dd></div>
        </dl>
        <p class="callout danger @(string.IsNullOrWhiteSpace(Model.Status.ErrorMessage) ? "is-hidden" : null)" data-status-error>@Model.Status.ErrorMessage</p>

        <section class="connection-section">
            <div class="section-heading">
                <div>
                    <p class="eyebrow">Connection</p>
                    <h3>Health Probes</h3>
                </div>
            </div>
            <p class="muted connection-section-copy">
                Use connection health menu in Status header to inspect each dependency, status, and probe detail.
            </p>

            @if (Model.IsDevelopment && (User.IsInRole("Admin") || User.IsInRole("BreakGlassAdmin")))
            {
                <div class="connection-toolbar">
                    <div>
                        <p class="muted connection-toolbar-copy">
                            Development-only override.
                            Default for this environment is @(Model.DefaultHealthProbesEnabled ? "enabled" : "disabled").
                            Default frequency is every @Model.DefaultHealthProbeIntervalSeconds seconds.
                            @(Model.HealthProbesUseOverride ? "A runtime override is currently active." : "No runtime override is saved.")
                        </p>
                    </div>
                    <div class="connection-toolbar-actions">
                        <form method="post" asp-page-handler="SetHealthProbeFrequency" class="connection-toolbar-form connection-toolbar-frequency-form">
                            <label>
                                <span>Frequency (seconds)</span>
                                <input type="number" name="intervalSeconds" value="@Model.HealthProbeIntervalSeconds" min="@SyncFactors.Api.DashboardSettingsProvider.MinHealthProbeIntervalSeconds" max="@SyncFactors.Api.DashboardSettingsProvider.MaxHealthProbeIntervalSeconds" step="1" />
                            </label>
                            <button class="link-button subtle-button" type="submit">Save frequency</button>
                        </form>
                        <form method="post" asp-page-handler="SetHealthProbes" class="connection-toolbar-form">
                            <input type="hidden" name="enabled" value="@(Model.HealthProbesEnabled ? "false" : "true")" />
                            <button class="link-button subtle-button" type="submit">@(Model.HealthProbesEnabled ? "Disable probes" : "Enable probes")</button>
                        </form>
                    </div>
                </div>
                <div class="connection-toolbar-meta">
                    <span class="badge info">Current frequency: @Model.HealthProbeIntervalSeconds s</span>
                    <span class="badge dim">Allowed range: @SyncFactors.Api.DashboardSettingsProvider.MinHealthProbeIntervalSeconds-@SyncFactors.Api.DashboardSettingsProvider.MaxHealthProbeIntervalSeconds s</span>
                </div>
            }
        </section>
    </article>

    <article class="panel recent-runs-panel">
        <div class="recent-runs-header">
            <div class="recent-runs-header-copy">
                <h2>Recent Runs</h2>
                <p class="muted dashboard-refresh-note" data-dashboard-checked>Live data is refreshed automatically while this page is open.</p>
            </div>
        </div>
        <section class="dashboard-timeline-card analytics-card" aria-label="Focused run timeline">
            <div class="section-heading">
                <div>
                    <p class="eyebrow">Run Timeline</p>
                    <h3 data-run-timeline-title>Runtime focus</h3>
                </div>
            </div>
            <p class="muted analytics-meta" data-run-timeline-summary>Select a run from a chart or table row to focus its timeline.</p>
            <ol class="run-timeline" data-run-timeline></ol>
            <p class="muted analytics-empty is-hidden" data-run-timeline-empty>No timeline data is available yet.</p>
        </section>
        <section class="dashboard-analytics-grid" aria-label="Run analytics">
            <article class="analytics-card">
                <div class="section-heading">
                    <div>
                        <p class="eyebrow">Run Volume</p>
                        <h3>Recent Run Mix</h3>
                    </div>
                </div>
                <div class="analytics-chart" data-runs-chart role="img" aria-label="Recent run mix chart"></div>
                <p class="muted analytics-empty is-hidden" data-runs-chart-empty>Recent runs will appear here once the dashboard has data to chart.</p>
            </article>
            <article class="analytics-card">
                <div class="section-heading">
                    <div>
                        <p class="eyebrow">Bucket Focus</p>
                        <h3>Run Composition</h3>
                    </div>
                </div>
                <p class="muted analytics-meta" data-buckets-chart-meta>Run composition appears once a run summary is available.</p>
                <div class="analytics-chart analytics-chart-compact" data-buckets-chart role="img" aria-label="Run composition chart"></div>
                <p class="muted analytics-empty is-hidden" data-buckets-chart-empty>Run composition appears once a run summary is available.</p>
            </article>
        </section>
        <div data-runs-empty class="@(Model.Runs.Count == 0 ? null : "is-hidden")">
            <p class="muted">No run data is configured yet. Set <code>SyncFactors__SqlitePath</code> to point the rewrite UI at an operational SQLite store.</p>
        </div>
        <div class="table-scroll @(Model.Runs.Count == 0 ? "is-hidden" : null)">
            <table class="data-table compact recent-runs-table" data-runs-table>
                <thead>
                    <tr>
                        <th class="recent-runs-table__started">Started</th>
                        <th class="recent-runs-table__trigger">Trigger</th>
                        <th class="recent-runs-table__mode">Run</th>
                        <th class="recent-runs-table__status">Status</th>
                        <th class="recent-runs-table__dry-run">Dry Run</th>
                        <th class="recent-runs-table__workers">Workers</th>
                        <th class="recent-runs-table__summary">Summary</th>
                        <th class="recent-runs-table__actions">Actions</th>
                    </tr>
                </thead>
                <tbody data-runs-body>
                @foreach (var run in initialRuns)
                {
                    <tr>
                        <td class="recent-runs-table__started">@SyncFactors.Api.UiDateTimeFormatter.FormatDateTime(run.StartedAt)</td>
                        <td class="recent-runs-table__trigger">@SyncFactors.Api.UiRunFormatting.DisplayLabel(run.RunTrigger)</td>
                        <td class="recent-runs-table__mode" title="@run.RunId">@SyncFactors.Api.UiRunFormatting.RunDisplayName(run)</td>
                        <td class="recent-runs-table__status"><span class="badge @SyncFactors.Api.UiRunFormatting.StatusBadgeTone(run.Status)">@SyncFactors.Api.UiRunFormatting.DisplayLabel(run.Status)</span></td>
                        <td class="recent-runs-table__dry-run">@(run.DryRun ? "Yes" : "No")</td>
                        <td class="recent-runs-table__workers">@run.TotalWorkers</td>
                        <td class="recent-runs-table__summary" title="@SyncFactors.Api.UiRunFormatting.RunBucketSummary(run)"><span class="summary-value">@SyncFactors.Api.UiRunFormatting.RunBucketSummary(run)</span></td>
                        <td class="recent-runs-table__actions"><a asp-page="/Runs/Detail" asp-route-runId="@run.RunId">Open</a></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <div class="runs-pagination @(Model.Runs.Count <= initialRunsPageSize ? "is-hidden" : null)" data-runs-pagination>
            <p class="muted runs-pagination__summary" data-runs-pagination-summary>
                @(Model.Runs.Count == 0 ? string.Empty : $"Showing 1-{initialRunsEnd} of {Model.Runs.Count} recent runs.")
            </p>
            <div class="runs-pagination__actions">
                <button class="link-button subtle-button" type="button" data-runs-page-previous disabled>Previous</button>
                <button class="link-button subtle-button" type="button" data-runs-page-next disabled="@(!initialHasMoreRuns)">Next</button>
            </div>
        </div>
    </article>
</section>

<script src="~/dist/dashboard.js" asp-append-version="true"></script>

@functions {
    private static string StatusVisualState(SyncFactors.Contracts.RuntimeStatus status)
    {
        var currentStatus = status.Status?.Trim() ?? string.Empty;
        var currentStage = status.Stage?.Trim() ?? string.Empty;

        if (currentStatus.Equals("Failed", StringComparison.OrdinalIgnoreCase))
        {
            return "failed";
        }

        if (currentStatus.Equals("Canceled", StringComparison.OrdinalIgnoreCase) ||
            currentStatus.Equals("Cancelled", StringComparison.OrdinalIgnoreCase))
        {
            return "idle";
        }

        if (currentStatus.Equals("Planned", StringComparison.OrdinalIgnoreCase) ||
            currentStatus.Equals("Pending", StringComparison.OrdinalIgnoreCase) ||
            currentStatus.Equals("CancelRequested", StringComparison.OrdinalIgnoreCase))
        {
            return "queued";
        }

        if (currentStatus.Equals("InProgress", StringComparison.OrdinalIgnoreCase))
        {
            if (currentStage.Equals("Starting", StringComparison.OrdinalIgnoreCase))
            {
                return "starting";
            }

            return "syncing";
        }

        if ((currentStatus.Equals("Idle", StringComparison.OrdinalIgnoreCase) || currentStatus.Equals("Succeeded", StringComparison.OrdinalIgnoreCase)) &&
            currentStage.Equals("Completed", StringComparison.OrdinalIgnoreCase) &&
            status.TotalWorkers > 0)
        {
            return "complete";
        }

        return "idle";
    }

    private static string StatusLine(SyncFactors.Contracts.RuntimeStatus status)
    {
        var visualState = StatusVisualState(status);

        return visualState switch
        {
            "starting" => "Starting a new sync run",
            "syncing" => status.TotalWorkers > 0
                ? $"Syncing worker {Math.Min(status.ProcessedWorkers + (string.IsNullOrWhiteSpace(status.CurrentWorkerId) ? 0 : 1), status.TotalWorkers)} of {status.TotalWorkers}"
                : "Syncing directory changes",
            "queued" => "Sync queued and waiting to start",
            "failed" => $"Sync stopped during {DisplayStage(status.Stage)}",
            "complete" => "Last sync completed successfully",
            _ => "Idle and ready for the next sync",
        };
    }

    private static string StatusCaption(SyncFactors.Contracts.RuntimeStatus status)
    {
        var visualState = StatusVisualState(status);
        var stage = DisplayStage(status.Stage);

        return visualState switch
        {
            "starting" =>
                string.IsNullOrWhiteSpace(status.RunId)
                    ? "The worker has claimed the next run and is preparing to process workers."
                    : $"Run {status.RunId} has been claimed and is preparing worker data.",
            "syncing" when !string.IsNullOrWhiteSpace(status.CurrentWorkerId) =>
                $"{stage} on worker {status.CurrentWorkerId}. {status.ProcessedWorkers} of {status.TotalWorkers} processed.",
            "syncing" =>
                $"{stage}. {status.ProcessedWorkers} of {status.TotalWorkers} workers processed.",
            "queued" =>
                string.IsNullOrWhiteSpace(status.RunId)
                    ? "The runtime is waiting for the worker service to begin the next run."
                    : $"Run {status.RunId} is staged and waiting for execution.",
            "failed" =>
                string.IsNullOrWhiteSpace(status.ErrorMessage)
                    ? "Review the last error and recent runs for the failure cause."
                    : status.ErrorMessage!,
            "complete" =>
                $"{status.ProcessedWorkers} of {status.TotalWorkers} workers were processed in the last completed run.",
            _ =>
                status.LastUpdatedAt is null
                    ? "No active sync is running."
                    : $"Last activity was {DisplayStage(status.Stage)}.",
        };
    }

    private static string DisplayStage(string? stage) =>
        string.IsNullOrWhiteSpace(stage) || stage.Equals("NotStarted", StringComparison.OrdinalIgnoreCase)
            ? "standby"
            : stage.Replace("InProgress", "in progress", StringComparison.OrdinalIgnoreCase).ToLowerInvariant();

    private static bool IsCanceledState(SyncFactors.Contracts.RuntimeStatus status) =>
        status.Status.Equals("Canceled", StringComparison.OrdinalIgnoreCase) ||
        status.Status.Equals("Cancelled", StringComparison.OrdinalIgnoreCase) ||
        status.Stage.Equals("Canceled", StringComparison.OrdinalIgnoreCase) ||
        status.Stage.Equals("Cancelled", StringComparison.OrdinalIgnoreCase);

    private static int WorkerProgressPercent(SyncFactors.Contracts.RuntimeStatus status)
    {
        if (status.TotalWorkers <= 0)
        {
            return 0;
        }

        return (int)Math.Round((status.ProcessedWorkers / (double)status.TotalWorkers) * 100, MidpointRounding.AwayFromZero);
    }

    private static string ProgressVisualState(SyncFactors.Contracts.RuntimeStatus status)
    {
        var currentStatus = status.Status?.Trim() ?? string.Empty;
        var currentStage = status.Stage?.Trim() ?? string.Empty;

        if (currentStatus.Equals("Failed", StringComparison.OrdinalIgnoreCase))
        {
            return "failed";
        }

        if (currentStatus.Equals("CancelRequested", StringComparison.OrdinalIgnoreCase))
        {
            return "canceling";
        }

        if (currentStatus.Equals("Canceled", StringComparison.OrdinalIgnoreCase) ||
            currentStatus.Equals("Cancelled", StringComparison.OrdinalIgnoreCase) ||
            currentStage.Equals("Canceled", StringComparison.OrdinalIgnoreCase) ||
            currentStage.Equals("Cancelled", StringComparison.OrdinalIgnoreCase))
        {
            return "canceled";
        }

        if (currentStatus.Equals("Planned", StringComparison.OrdinalIgnoreCase) ||
            currentStatus.Equals("Pending", StringComparison.OrdinalIgnoreCase))
        {
            return "queued";
        }

        if (currentStatus.Equals("InProgress", StringComparison.OrdinalIgnoreCase))
        {
            if (currentStage.Equals("Starting", StringComparison.OrdinalIgnoreCase))
            {
                return "starting";
            }

            if (currentStage.Equals("Planning", StringComparison.OrdinalIgnoreCase))
            {
                return "planning";
            }

            if (currentStage.Equals("ApplyPreview", StringComparison.OrdinalIgnoreCase))
            {
                return "applypreview";
            }

            return "syncing";
        }

        if ((currentStatus.Equals("Idle", StringComparison.OrdinalIgnoreCase) || currentStatus.Equals("Succeeded", StringComparison.OrdinalIgnoreCase)) &&
            currentStage.Equals("Completed", StringComparison.OrdinalIgnoreCase) &&
            status.TotalWorkers > 0)
        {
            return "complete";
        }

        return "idle";
    }

    private static int ProgressFillWidth(SyncFactors.Contracts.RuntimeStatus status)
    {
        var actualPercent = WorkerProgressPercent(status);

        return ProgressVisualState(status) switch
        {
            "starting" => 18,
            "queued" => 16,
            "canceling" => 32,
            "planning" => Math.Max(actualPercent, 18),
            "applypreview" => Math.Max(actualPercent, 38),
            "syncing" => status.TotalWorkers > 0 ? Math.Max(actualPercent, 12) : 26,
            "complete" => 100,
            "failed" => status.TotalWorkers > 0 ? Math.Max(actualPercent, 18) : 100,
            "canceled" => 18,
            _ => 8,
        };
    }

    private static string ProgressLabel(SyncFactors.Contracts.RuntimeStatus status)
    {
        var actualPercent = WorkerProgressPercent(status);

        return ProgressVisualState(status) switch
        {
            "starting" => "Starting",
            "queued" => "Queued",
            "canceling" => "Canceling",
            "planning" => "Planning",
            "applypreview" => actualPercent > 0 ? $"Applying {actualPercent}%" : "Applying Preview",
            "syncing" => actualPercent > 0 ? $"Syncing {actualPercent}%" : "Syncing",
            "complete" => "Done",
            "failed" => "Failed",
            "canceled" => "Canceled",
            _ => "Idle",
        };
    }

    private static string ProgressCopy(SyncFactors.Contracts.RuntimeStatus status)
    {
        var visualState = ProgressVisualState(status);
        var stage = DisplayStage(status.Stage);

        return visualState switch
        {
            "starting" =>
                string.IsNullOrWhiteSpace(status.RunId)
                    ? "The worker has claimed the run and is loading source workers."
                    : $"Run {status.RunId} has started and is loading source workers.",
            "queued" =>
                string.IsNullOrWhiteSpace(status.RunId)
                    ? "The next sync is queued and waiting for the worker service."
                    : $"Run {status.RunId} is queued and waiting for the worker service.",
            "canceling" =>
                "Cancellation has been requested. The worker will stop after the current operation.",
            "planning" =>
                "Building the sync plan before directory changes are applied.",
            "applypreview" =>
                string.IsNullOrWhiteSpace(status.CurrentWorkerId)
                    ? "Applying the reviewed preview to Active Directory."
                    : $"Applying the reviewed preview for worker {status.CurrentWorkerId}.",
            "syncing" when status.TotalWorkers > 0 =>
                $"{status.ProcessedWorkers} of {status.TotalWorkers} workers are accounted for in the current run.",
            "syncing" =>
                $"Sync activity is running during {stage}.",
            "complete" =>
                $"{status.ProcessedWorkers} of {status.TotalWorkers} workers were processed in the last completed run.",
            "failed" =>
                string.IsNullOrWhiteSpace(status.ErrorMessage)
                    ? $"The sync failed during {stage}."
                    : status.ErrorMessage!,
            "canceled" =>
                "The last sync was canceled before worker progress completed.",
            _ =>
                status.LastUpdatedAt is null
                    ? "No active worker progress has been recorded yet."
                    : $"Last worker activity was {stage}.",
        };
    }
}
