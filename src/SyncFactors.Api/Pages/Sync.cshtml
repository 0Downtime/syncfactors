@page
@model SyncFactors.Api.Pages.SyncModel
@{
    ViewData["Title"] = "Sync";
}

<section class="hero hero-compact">
    <div>
        <p class="eyebrow">Provisioning Control</p>
        <h1>Sync</h1>
        <p class="lede">Queue ad hoc AD provisioning runs and manage the recurring full-sync schedule.</p>
    </div>
    <div class="hero-actions">
        <button type="button" class="link-button danger-button" data-open-delete-dialog disabled="@Model.HasPendingOrActiveRun">Testing Reset</button>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <section class="panel">
        <p class="callout danger">@Model.ErrorMessage</p>
    </section>
}

@if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
{
    <section class="panel">
        <p class="callout good">@Model.SuccessMessage</p>
    </section>
}

<section class="panel-grid dashboard-grid sync-dashboard-grid">
    <article class="panel sync-current-run-panel">
        <h2>Current Run</h2>
        <dl class="kv">
            <div><dt>Status</dt><dd>@Model.Status.Status</dd></div>
            <div><dt>Stage</dt><dd>@Model.Status.Stage</dd></div>
            <div><dt>Run Id</dt><dd>@(Model.Status.RunId ?? "None")</dd></div>
            <div><dt>Trigger</dt><dd>@(Model.ActiveRun?.RunTrigger ?? "n/a")</dd></div>
            <div><dt>Requested By</dt><dd>@(Model.ActiveRun?.RequestedBy ?? "n/a")</dd></div>
            <div><dt>Progress</dt><dd>@Model.Status.ProcessedWorkers / @Model.Status.TotalWorkers</dd></div>
            <div><dt>Last Action</dt><dd>@(Model.Status.LastAction ?? "None")</dd></div>
            <div><dt>Last Updated</dt><dd>@(Model.Status.LastUpdatedAt?.ToString("u") ?? "Unknown")</dd></div>
        </dl>
        @if (Model.ActiveRun is not null)
        {
            <p><a asp-page="/Runs/Detail" asp-route-runId="@Model.ActiveRun.RunId">Open active run</a></p>
        }
    </article>

    <article class="panel sync-ad-hoc-panel">
        <h2>Ad Hoc Run</h2>
        <p class="muted">Full-source sync only. Dry-run is the default and safest option.</p>
        @if (Model.HasPendingOrActiveRun)
        {
            <p class="callout warn">A run is already pending or active. You can request cancellation and the worker will stop gracefully.</p>
        }
        <form method="post" asp-page-handler="@(Model.HasPendingOrActiveRun ? "CancelRun" : "StartRun")" class="filters">
            <label>
                <span>Run type</span>
                <select asp-for="RunMode" disabled="@Model.HasPendingOrActiveRun">
                    <option value="DryRun">Dry run</option>
                    <option value="LiveRun">Live provisioning</option>
                </select>
            </label>
            <div class="filter-actions">
                <button type="submit" disabled="@(string.Equals(Model.CurrentQueueRequest?.Status, "CancelRequested", StringComparison.OrdinalIgnoreCase))">
                    @(string.Equals(Model.CurrentQueueRequest?.Status, "CancelRequested", StringComparison.OrdinalIgnoreCase) ? "Cancel requested" : Model.HasPendingOrActiveRun ? "Cancel run" : "Queue run")
                </button>
            </div>
        </form>
    </article>

    <article class="panel sync-schedule-panel">
        <h2>Recurring Schedule</h2>
        <dl class="kv">
            <div><dt>Enabled</dt><dd>@(Model.Schedule.Enabled ? "Yes" : "No")</dd></div>
            <div><dt>Interval</dt><dd>@Model.Schedule.IntervalMinutes minutes</dd></div>
            <div><dt>Next Run</dt><dd>@(Model.Schedule.NextRunAt?.ToString("u") ?? "Not scheduled")</dd></div>
            <div><dt>Last Scheduled</dt><dd>@(Model.Schedule.LastScheduledRunAt?.ToString("u") ?? "Never")</dd></div>
            <div><dt>Last Enqueue Attempt</dt><dd>@(Model.Schedule.LastEnqueueAttemptAt?.ToString("u") ?? "Never")</dd></div>
        </dl>
        @if (!string.IsNullOrWhiteSpace(Model.Schedule.LastEnqueueError))
        {
            <p class="callout warn">@Model.Schedule.LastEnqueueError</p>
        }
        <form method="post" asp-page-handler="SaveSchedule" class="filters">
            <label>
                <span>Enabled</span>
                <input asp-for="ScheduleEnabled" type="checkbox" />
            </label>
            <label>
                <span>Interval minutes</span>
                <input asp-for="IntervalMinutes" type="number" min="5" max="1440" step="1" />
            </label>
            <div class="filter-actions">
                <button type="submit">Save schedule</button>
            </div>
        </form>
    </article>
</section>

<dialog class="confirm-dialog" data-delete-dialog data-delete-required-text="@SyncFactors.Api.Pages.SyncModel.DeleteAllUsersConfirmationPhrase">
    <form method="dialog" class="confirm-dialog__surface">
        <div class="section-heading">
            <div>
                <p class="eyebrow">Danger Zone</p>
                <h2>Delete All Users</h2>
            </div>
        </div>
        <p class="muted">This queues a live delete job against all users currently returned by the worker source. Type <strong>@SyncFactors.Api.Pages.SyncModel.DeleteAllUsersConfirmationPhrase</strong> to continue.</p>
        <label>
            <span>Confirmation text</span>
            <input type="text" name="confirmationText" data-delete-confirmation-input autocomplete="off" />
        </label>
        <div class="filter-actions">
            <button type="button" class="link-button" data-close-delete-dialog>Cancel</button>
        </div>
    </form>
    <form method="post" asp-page-handler="DeleteAllUsers" class="confirm-dialog__surface confirm-dialog__surface--danger">
        <input type="hidden" asp-for="DeleteAllUsersConfirmationText" data-delete-confirmation-hidden />
        <p class="muted">The run will appear in history like any other queued job.</p>
        <div class="filter-actions">
            <button type="button" class="link-button" data-close-delete-dialog>Go back</button>
            <button type="submit" class="danger-button" data-submit-delete-dialog disabled>Queue delete-all run</button>
        </div>
    </form>
</dialog>

<section class="panel">
    <div class="section-heading">
        <div>
            <p class="eyebrow">History</p>
            <h2>Recent Runs</h2>
        </div>
        <a class="link-button" asp-page="/Index">Back to dashboard</a>
    </div>
    @if (Model.Runs.Count == 0)
    {
        <p class="muted">No runs have been recorded yet.</p>
    }
    else
    {
        <div class="table-scroll">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Started</th>
                        <th>Trigger</th>
                        <th>Status</th>
                        <th>Scope</th>
                        <th>Dry Run</th>
                        <th>Workers</th>
                        <th>Requested By</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var run in Model.Runs)
                {
                    <tr>
                        <td>@run.StartedAt.ToString("u")</td>
                        <td>@run.RunTrigger</td>
                        <td><span class="badge @StatusClass(run.Status)">@run.Status</span></td>
                        <td>@run.SyncScope</td>
                        <td>@(run.DryRun ? "Yes" : "No")</td>
                        <td>@run.TotalWorkers</td>
                        <td>@(run.RequestedBy ?? "n/a")</td>
                        <td><a asp-page="/Runs/Detail" asp-route-runId="@run.RunId">Open</a></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <div class="table-pagination">
            <p class="muted">Showing page @Model.PageNumber of @Model.TotalRunPages (@Model.TotalRunsCount total runs).</p>
            <div class="filter-actions">
                @if (Model.HasPreviousRunPage)
                {
                    <a class="link-button" asp-page="/Sync" asp-route-pageNumber="@(Model.PageNumber - 1)">Previous</a>
                }
                @if (Model.HasNextRunPage)
                {
                    <a class="link-button" asp-page="/Sync" asp-route-pageNumber="@(Model.PageNumber + 1)">Next</a>
                }
            </div>
        </div>
    }
</section>

@functions {
    private static string StatusClass(string status) =>
        status.ToLowerInvariant() switch
        {
            "succeeded" => "good",
            "failed" => "bad",
            "inprogress" => "warn",
            "canceled" => "neutral",
            _ => "neutral",
        };
}

<script src="~/js/sync.js" asp-append-version="true"></script>
