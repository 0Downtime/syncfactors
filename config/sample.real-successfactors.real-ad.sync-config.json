{
  "secrets": {
    "successFactorsUsernameEnv": "SF_AD_SYNC_SF_USERNAME",
    "successFactorsPasswordEnv": "SF_AD_SYNC_SF_PASSWORD",
    "adServerEnv": "SF_AD_SYNC_AD_SERVER",
    "adUsernameEnv": "SF_AD_SYNC_AD_USERNAME",
    "adBindPasswordEnv": "SF_AD_SYNC_AD_BIND_PASSWORD",
    "defaultAdPasswordEnv": "SF_AD_SYNC_AD_DEFAULT_PASSWORD"
  },
  "successFactors": {
    "baseUrl": "https://api12.successfactors.com/odata/v2",
    "auth": {
      "mode": "basic",
      "basic": {
        "username": "replace-me",
        "password": "replace-me"
      },
      "oauth": {
        "tokenUrl": "https://example.authentication.successfactors.com/oauth/token",
        "clientAuthentication": "body",
        "clientId": "",
        "clientSecret": "",
        "companyId": ""
      }
    },
    "query": {
      "entitySet": "PerPerson",
      "identityField": "personIdExternal",
      "deltaField": "lastModifiedDateTime",
      "baseFilter": "employmentNav/jobInfoNav/emplStatus in 'A','U'",
      "select": [
        "personIdExternal",
        "firstName",
        "lastName",
        "status",
        "startDate",
        "department",
        "company",
        "location",
        "email",
        "managerEmployeeId",
        "employmentNav/jobInfoNav/jobTitle",
        "employmentNav/jobInfoNav/businessUnit",
        "employmentNav/jobInfoNav/division",
        "employmentNav/jobInfoNav/costCenter",
        "employmentNav/jobInfoNav/employeeClass",
        "employmentNav/jobInfoNav/employmentType"
      ],
      "expand": [
        "employmentNav",
        "employmentNav/jobInfoNav"
      ]
    },
    "previewQuery": {
      "select": [
        "personIdExternal",
        "firstName",
        "lastName"
      ],
      "expand": []
    }
  },
  "ad": {
    "server": "",
    "username": "",
    "bindPassword": "",
    "identityAttribute": "employeeID",
    "defaultActiveOu": "OU=Employees,DC=example,DC=com",
    "graveyardOu": "OU=Graveyard,DC=example,DC=com",
    "defaultPassword": "Replace-This-Password123!",
    "ouRoutingRules": [
      {
        "match": {
          "company": "CORP",
          "department": "IT"
        },
        "targetOu": "OU=IT,OU=Employees,DC=example,DC=com"
      }
    ],
    "licensingGroups": [
      "CN=M365-E3-Prestage,OU=Groups,DC=example,DC=com"
    ]
  },
  "sync": {
    "enableBeforeStartDays": 7,
    "deletionRetentionDays": 90
  },
  "safety": {
    "maxCreatesPerRun": 25,
    "maxDisablesPerRun": 25,
    "maxDeletionsPerRun": 10
  },
  "state": {
    "path": ".\\state\\runtime\\sync-state.json"
  },
  "reporting": {
    "outputDirectory": ".\\reports\\output"
  }
}
