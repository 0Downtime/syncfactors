{
  "name": "recovery-rerun-after-partial",
  "tags": ["recovery", "real-ad", "production-readiness"],
  "riskLevel": "recovery",
  "preflight": {
    "apiHealth": true,
    "mockHealth": true,
    "workerHeartbeat": true,
    "activeDirectory": true,
    "managedOuSnapshot": true
  },
  "expectedQueueStatus": "Completed",
  "expectedRunStatus": "Succeeded",
  "expectedDurationSeconds": 240,
  "resetAdBeforeScenario": true,
  "resetMockBeforeScenario": true,
  "syncMode": "BulkSync",
  "iterations": [
    {
      "order": 1,
      "name": "create-before-rerun",
      "mutations": [
        {
          "workerId": "10003",
          "set": {
            "startDate": "2026-03-15",
            "lifecycleState": "active",
            "employmentStatus": "64300",
            "emplStatus": "64300",
            "company": "CORP Recovery"
          }
        }
      ],
      "expectation": {
        "runStatus": "Succeeded",
        "bucketCounts": {
          "creates": 1
        },
        "workerOperations": [
          {
            "workerId": "10003",
            "operations": ["CreateUser"]
          }
        ]
      }
    },
    {
      "order": 2,
      "name": "rerun-without-source-change",
      "mutations": [],
      "expectation": {
        "runStatus": "Succeeded",
        "bucketCounts": {
          "unchanged": 1
        },
        "workerOperations": []
      }
    }
  ],
  "finalExpectation": {
    "expectedAdUsers": [
      {
        "workerId": "10003",
        "samAccountName": "10003",
        "parentOu": "OU=Active,OU=SyncFactors-Users,DC=example,DC=test",
        "enabled": true,
        "attributes": {
          "employeeID": "10003",
          "company": "CORP Recovery"
        }
      }
    ]
  }
}
